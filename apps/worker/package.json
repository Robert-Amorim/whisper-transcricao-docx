{
  "name": "@whisper-transcricao/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build --workspace @whisper-transcricao/shared && tsc -p tsconfig.build.json",
    "start": "npm run build --workspace @whisper-transcricao/shared && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@whisper-transcricao/shared": "*",
    "bullmq": "^5.48.1",
    "dotenv": "^16.6.1",
    "oci-common": "^2.125.3",
    "oci-objectstorage": "^2.125.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
