{
  "name": "@voxora/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build --workspace @voxora/shared && npm run prisma:generate && tsc -p tsconfig.build.json",
    "start": "npm run build --workspace @voxora/shared && node dist/index.js",
    "typecheck": "npm run build --workspace @voxora/shared && tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:dashboard-mock": "node scripts/seed-dashboard-mock.cjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.6.0",
    "@voxora/shared": "*",
    "argon2": "^0.41.1",
    "bullmq": "^5.48.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "oci-common": "^2.125.3",
    "oci-objectstorage": "^2.125.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
